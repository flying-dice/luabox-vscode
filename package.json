{
  "name": "luabox",
  "displayName": "luabox",
  "description": "luabox language support: typecheck, lint, hover, goto-def and completion for Lua, powered by `luabox lsp`.",
  "version": "0.3.0",
  "publisher": "luabox",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "keywords": [
    "lua",
    "luabox",
    "lsp",
    "typecheck"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/flying-dice/luabox-vscode"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:lua",
    "workspaceContains:luabox.toml"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "luabox",
          "title": "luabox",
          "icon": "media/luabox.svg"
        }
      ]
    },
    "views": {
      "luabox": [
        {
          "type": "webview",
          "id": "luabox.packages",
          "name": "Packages"
        },
        {
          "id": "luabox.installed",
          "name": "Installed dependencies"
        }
      ]
    },
    "commands": [
      {
        "command": "luabox.restartServer",
        "title": "luabox: Restart Language Server"
      },
      {
        "command": "luabox.packages.refresh",
        "title": "Refresh",
        "category": "luabox",
        "icon": "$(refresh)"
      },
      {
        "command": "luabox.packages.search",
        "title": "Search packages",
        "category": "luabox",
        "icon": "$(search)"
      },
      {
        "command": "luabox.packages.update",
        "title": "Update to latest",
        "category": "luabox",
        "icon": "$(arrow-circle-up)"
      },
      {
        "command": "luabox.packages.remove",
        "title": "Remove dependency",
        "category": "luabox",
        "icon": "$(trash)"
      },
      {
        "command": "luabox.signInGithub",
        "title": "Sign in to GitHub",
        "category": "luabox"
      },
      {
        "command": "luabox.signOutGithub",
        "title": "Sign out of GitHub",
        "category": "luabox"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "luabox.packages.search",
          "when": "view == luabox.packages",
          "group": "navigation@1"
        },
        {
          "command": "luabox.packages.refresh",
          "when": "view == luabox.installed",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "luabox.packages.update",
          "when": "view == luabox.installed && viewItem == depOutdated",
          "group": "inline@1"
        },
        {
          "command": "luabox.packages.remove",
          "when": "view == luabox.installed && (viewItem == depOutdated || viewItem == depCurrent || viewItem == depOther)",
          "group": "inline@2"
        }
      ],
      "commandPalette": [
        {
          "command": "luabox.packages.update",
          "when": "false"
        },
        {
          "command": "luabox.packages.remove",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "luabox",
      "properties": {
        "luabox.path": {
          "type": "string",
          "default": "luabox",
          "description": "Path to the `luabox` executable. When left as a bare name it is resolved on PATH. The language server is launched as `<path> lsp`."
        },
        "luabox.githubToken": {
          "type": "string",
          "default": "",
          "markdownDescription": "**Optional, for git-source dependencies only.** The package registry (luarocks.org) is anonymous and never needs this. It only matters for `git` dependencies (`luabox add --git`): release-tag probing in `luabox outdated`/`luabox update` hits the GitHub API, which rate-limits unauthenticated calls. Normally the extension uses your VS Code GitHub sign-in automatically (the Accounts menu) — no token needed. Set a Personal Access Token here only for setups the native sign-in can't cover, e.g. GitHub Enterprise or restricted orgs. When set, it takes precedence over the native session and is passed to the `luabox` CLI as the `LUABOX_GITHUB_TOKEN` environment variable (never logged). A read-only token with `public_repo` scope is sufficient.",
          "scope": "machine-overridable"
        },
        "luabox.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace the communication between VS Code and the luabox language server."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run check-types && npm run bundle -- --minify",
    "compile": "npm run check-types && npm run bundle",
    "check-types": "tsc -p ./ --noEmit",
    "bundle": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run bundle -- --watch",
    "test": "esbuild ./src/authToken.test.ts --bundle --outfile=out/authToken.test.cjs --format=cjs --platform=node && esbuild ./src/parse.test.ts --bundle --outfile=out/parse.test.cjs --format=cjs --platform=node && node --test out/authToken.test.cjs out/parse.test.cjs",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "typescript": "^5.4.0"
  }
}
